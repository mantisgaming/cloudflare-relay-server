{
	"name": "totsm-cloudflare-relay",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"predev": "npm run reset-local-db",
		"dev": "wrangler dev --test-scheduled -e=staging --local",
		"demo-site": "npx http-server ./demo-site -p 8080",
		"start": "wrangler dev",
		"cf-typegen": "wrangler types",
		"reset-local-db": "wrangler d1 execute RELAY_D1 --local -e staging --file=./RELAY_D1_schema.sql"
	},
	"devDependencies": {
		"typescript": "^5.5.2",
		"wrangler": "^4.62.0"
	},
	"dependencies": {
		"itty-router": "^5.0.22"
	}
}
